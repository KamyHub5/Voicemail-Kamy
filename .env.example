# Vonage Master API credentials (found in Vonage Dashboard → API Settings)
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Vonage Application ID (found in Vonage Dashboard → Applications → your app)
VONAGE_APP_ID=

# Vonage Private Key (generated when you created the Vonage application)
# Paste the entire key including BEGIN and END lines, wrapped in double quotes
VONAGE_PRIVATE_KEY=

# Your deployed Vercel URL (no trailing slash)
# Example: https://voicemail-kamy.vercel.app
BASE_URL=

# Your Vonage virtual number (the number people call, no + sign)
VONAGE_NUMBER=

# Kamy's real phone number (where calls get forwarded, no + sign)
KAMY_NUMBER=
